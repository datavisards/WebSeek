# WebSeek Chrome Extension – Environment Variables
# Copy this file to .env and fill in your values.

# Your OpenRouter API key (https://openrouter.ai/keys)
# This key is bundled into the extension build. Keep it secret.
WXT_OPENROUTER_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# LLM model for all frontend AI calls (optional — default shown)
# VITE_LLM_MODEL=google/gemini-2.5-flash
# VITE_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Backend server host and path — no protocol prefix, no trailing slash.
# The extension prepends http:// and ws:// automatically.
# For local development:   localhost:8000
# For lab server:          191host013.mobilenet.cse.ust.hk/webseek
VITE_BACKEND_URL=localhost:8000
VITE_BACKEND_WS_URL=localhost:8000
